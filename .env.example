# ─────────────────────────────────────────────────────────────────────────────
# EcoWitt → Windy Proxy – environment configuration template
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8888

# Directory where the latest EcoWitt payload is stored (inside the container)
# DATA_DIR=/app/data

# ── Windy Stations API v2 ─────────────────────────────────────────────────────
# Get these from https://stations.windy.com/stations → station detail page.
# WINDY_STATION_ID is the short hex ID shown on the station page.
# WINDY_STATION_PASSWORD is the auto-generated station password (not the API key).
WINDY_STATION_ID=your_station_id_here
WINDY_STATION_PASSWORD=your_windy_station_password_here
PUSHOVER_KEY=pushoever_key_here